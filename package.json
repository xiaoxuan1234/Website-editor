{
  "name": "web-generator-v2",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.11.0",
  "scripts": {
    "dev": "pnpm --parallel --filter @wg/server --filter @wg/web dev",
    "dev:web": "pnpm --filter @wg/web dev",
    "dev:server": "pnpm --filter @wg/server dev",
    "build": "pnpm -r build",
    "build:web": "pnpm --filter @wg/web build",
    "build:server": "pnpm --filter @wg/server build",
    "test": "pnpm -r test",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.1"
  }
}
